{
  "permissions": {
    "allow": [
      "Bash(minikube version:*)",
      "Bash(kubectl version:*)",
      "Bash(kind version:*)",
      "Bash(docker version:*)",
      "Bash(kubectl cluster-info:*)",
      "Bash(kubectl config:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl wait:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(docker save:*)",
      "Bash(kubectl port-forward:*)",
      "Bash(curl -s http://localhost:8000/health)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8090/health)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8501)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(curl -s -u admin:admin http://localhost:8090/api/v1/dags)",
