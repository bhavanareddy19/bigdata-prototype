      "Bash(curl -s -u admin:admin -X POST http://localhost:8090/api/v1/dags/data_ingestion/dagRuns -H 'Content-Type: application/json' -d '{\"conf\": {}}')",
      "Bash(curl -s -u admin:admin \"http://localhost:8090/api/v1/dags/data_ingestion/dagRuns?order_by=-start_date&limit=1\")",
      "Bash(curl -s -u admin:admin \"http://localhost:8090/api/v1/dags/data_ingestion/dagRuns/manual__2026-04-04T21:26:15.437983+00:00/taskInstances\")",
      "Bash(kubectl logs:*)",
      "Bash(kubectl exec:*)",
      "Bash(curl -s -u admin:admin \"http://localhost:8090/api/v1/dags/data_ingestion/dagRuns\")",
      "Bash(kubectl rollout:*)",
      "Bash(curl -s -u admin:admin \"http://localhost:8090/api/v1/dags/data_ingestion/dagRuns/manual__2026-04-04T21:33:13.479356+00:00/taskInstances\")",
      "Bash(curl -s -u admin:admin -X PATCH http://localhost:8090/api/v1/dags/__TRACKED_VAR__ -H 'Content-Type: application/json' -d '{\"is_paused\": false}')",
      "Bash(curl -s -u admin:admin -X POST http://localhost:8090/api/v1/dags/data_transformation/dagRuns -H 'Content-Type: application/json' -d '{\"conf\": {}}')",
      "Bash(curl -s -u admin:admin -X POST http://localhost:8090/api/v1/dags/data_quality_checks/dagRuns -H 'Content-Type: application/json' -d '{\"conf\": {}}')",
      "Bash(curl -s -u admin:admin -X POST http://localhost:8090/api/v1/dags/ml_pipeline/dagRuns -H 'Content-Type: application/json' -d '{\"conf\": {}}')",
      "Bash(curl -s -u admin:admin 'http://localhost:8090/api/v1/dags/__TRACKED_VAR__/dagRuns?order_by=-start_date&limit=1')",
      "Bash(kubectl delete:*)",
      "Bash(curl -s -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"message\": \"What is the status of my pipelines?\", \"mode\": \"auto\"}')",
      "Bash(curl -s -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"message\": \"hello\", \"mode\": \"auto\"}')",
      "Bash(curl -s -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"question\": \"Why did ml_pipeline fail?\", \"mode\": \"auto\"}')",
      "Bash(docker build:*)",
      "Bash(curl -s -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"question\": \"What are todays failures?\", \"mode\": \"auto\"}')",
      "Bash(curl -v http://localhost:8000/health)",
      "Bash(pkill -f \"port-forward\")",
      "Bash(curl -s --max-time 90 -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"question\": \"What are todays failures?\", \"mode\": \"auto\"}')"
    ]
  }
}
