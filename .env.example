# Copy to .env and fill in values.

# LLM provider configuration
# Use a free open-source model locally via Ollama (recommended).
LLM_PROVIDER=ollama

# Ollama settings (free, local). Install Ollama and pull a model like `llama3.1:8b`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional OpenAI fallback (leave empty to disable).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Backend URL used by Streamlit UI (local default).
BACKEND_URL=http://localhost:8000
