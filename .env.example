# ═══════════════════════════════════════════════════════════════
# BigData Platform — Environment Configuration
# Copy this file to .env and adjust values.
# ═══════════════════════════════════════════════════════════════

# ── Ollama (free, local LLM) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Embedding model (sentence-transformers, runs locally) ────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB (vector store) ──────────────────────────────────
# Mode: "local" (in-process) or "server" (remote HTTP)
CHROMADB_MODE=local
CHROMADB_PERSIST_DIR=.chromadb
# Only needed if CHROMADB_MODE=server:
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8100

# ── Marquez / OpenLineage ────────────────────────────────────
MARQUEZ_URL=http://localhost:5000

# ── Airflow ──────────────────────────────────────────────────
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# ── Backend / Frontend ──────────────────────────────────────
BACKEND_URL=http://localhost:8000
