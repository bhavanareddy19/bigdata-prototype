APP_ENV=prod

BACKEND_URL=https://bigdata-backend-a2vn2ihr2a-uc.a.run.app
FRONTEND_URL=https://bigdata-frontend-a2vn2ihr2a-uc.a.run.app

# ── LLM: Vertex AI (production) ───────────────────────────
LLM_PROVIDER=vertex
VERTEX_PROJECT_ID=bda-project-gcp
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_PROJECT=bda-project-gcp
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# ── LLM: Ollama (local dev only — not used in GCP) ────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Vector DB ─────────────────────────────────────────────
# On Cloud Run, ChromaDB runs in-process in /tmp (ephemeral — OK for demo)
VECTOR_STORE_PROVIDER=chroma_local
CHROMADB_MODE=local
CHROMADB_PERSIST_DIR=/tmp/chromadb
CHROMADB_HOST=localhost
CHROMADB_PORT=8100

# ── Storage ───────────────────────────────────────────────
STORAGE_MODE=gcs
GCS_DATA_BUCKET=bda-project-gcp-data
GCS_LANDING_PREFIX=landing/
GCS_RAW_PREFIX=raw/
GCS_STAGING_PREFIX=staging/
GCS_PROCESSED_PREFIX=processed/
GCS_CURATED_PREFIX=curated/
GCS_FEATURES_PREFIX=features/
GCS_MODELS_PREFIX=models/

# ── Airflow / Cloud Composer ──────────────────────────────
AIRFLOW_BASE_URL=https://3d7249feafb548c683a6a11e7186446b-dot-us-central1.composer.googleusercontent.com
AIRFLOW_USERNAME=
AIRFLOW_PASSWORD=

# ── Lineage (Marquez — not yet cloud-deployed) ────────────
MARQUEZ_URL=
PIPELINE_NAMESPACE=bigdata-platform

# ── Embeddings ────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Database (not used in current demo) ──────────────────
DATABASE_URL=
